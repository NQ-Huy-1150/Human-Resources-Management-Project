<Page x:Class="layout.view.tuyendung.deletePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.tuyendung"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="deletePage">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Breadcrumb start -->
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" VerticalAlignment="Top">
                    <Button Content="Quản lý nhân sự" Height="25" Click="Button_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <Button Content="Tuyển dụng" Height="25" Click="backToParentBtn" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Xoá đơn" Margin="5,4,5,0" FontStyle="Italic" />
                </StackPanel>
                <!-- Breadcrumb end -->
                <!-- Content start-->
                <Rectangle Height="2" Margin="10,40,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <Label Content="Bạn chắc chắn muốn xoá đơn này ?" HorizontalAlignment="Left" Height="37" Margin="10,51,0,0" VerticalAlignment="Top" Width="316" FontSize="18" Foreground="Red" FontWeight="Bold"/>
                <Rectangle Height="2" Margin="10,83,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <StackPanel Orientation="Vertical" Margin="10,95,10,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" MinWidth="500">
                        <TextBlock Text="Mã đơn : " FontSize="14" Width="160" />
                        <TextBlock x:Name="recruitId" Width="200" />
                    </StackPanel>

                    <Rectangle Height="2" Margin="10,20,10,0" Fill="LightGray" VerticalAlignment="Bottom"/>
                    <Button Content="Xoá đơn tuyển dụng" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,5" Click="deleteBtn" Background="OrangeRed" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="Hoặc" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Content="Quay lại bảng tuyển dụng " FontSize="14" VerticalAlignment="Center" Margin="0,5,0,15" Click="backToParentBtn"/>
                </StackPanel>
                <!-- Content end-->
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
