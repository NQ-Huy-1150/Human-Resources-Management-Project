<Page x:Class="layout.view.chamcong.UserView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="UserView">

    <Grid Background="#F4F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50">
            <TextBlock Text="HỆ THỐNG CHẤM CÔNG NHÂN VIÊN" Foreground="White" VerticalAlignment="Center" 
                       Margin="20,0" FontWeight="Bold" FontSize="16"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="20,10,20,20">
            <GroupBox Header="Thao tác trong ngày" Padding="20" Background="White" BorderBrush="#D1D9E0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnVao" Content="VÀO CA" Click="btnVao_Click" Width="130" Height="45" 
                                Background="#27AE60" Foreground="White" FontWeight="Bold" Margin="10"/>
                        <Button x:Name="btnRa" Content="RA CA" Click="btnRa_Click" Width="130" Height="45" 
                                Background="#E67E22" Foreground="White" FontWeight="Bold" Margin="10"/>
                    </StackPanel>
                    <TextBlock x:Name="txtNotify" Foreground="#E74C3C" HorizontalAlignment="Center" 
                               Margin="0,10,0,0" FontWeight="SemiBold" Visibility="Collapsed"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="Lịch sử chấm công hôm nay" Margin="5,20,0,10" FontWeight="Bold" FontSize="15" Foreground="#2C3E50"/>

            <DataGrid x:Name="dgLichSu" Height="250" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="White" RowHeight="38" BorderBrush="#D1D9E0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Giờ vào" Binding="{Binding check_in, StringFormat='HH:mm:ss'}" Width="*"/>
                    <DataGridTextColumn Header="Giờ ra" Binding="{Binding check_out, StringFormat='HH:mm:ss'}" Width="*"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Đang làm việc">
                                        <Setter Property="Foreground" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>