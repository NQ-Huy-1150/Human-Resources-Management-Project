<Page x:Class="layout.view.chamcong.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.chamcong"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChamCongPage">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Breadcrumb start -->
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" VerticalAlignment="Top">
                    <Button Content="Quản lý nhân sự" Height="25"  BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <Button Content="Tuyển dụng" Height="25"  BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Xoá đơn" Margin="5,4,5,0" FontStyle="Italic" />
                </StackPanel>
                <!-- Breadcrumb end -->
                <!-- Content start-->
                <Rectangle Height="2" Margin="10,40,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <StackPanel Orientation="Vertical" Margin="10,80,10,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <DataGrid x:Name="dgAdmin" Grid.Row="1" Margin="15" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nhân Viên" Binding="{Binding ho_ten}" Width="1.5*"/>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding thoi_diem_vao, StringFormat='dd/MM/yyyy'}" Width="*"/>
                            <DataGridTextColumn Header="Tổng Giờ" Binding="{Binding ThoiGianChiTiet}" Width="*"/>

                            <DataGridTextColumn Header="Ca Thường (Phút)" Binding="{Binding CaBinhThuong}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#27AE60"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Tăng Ca (Phút)" Binding="{Binding TangCa}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Ghi Chú" Binding="{Binding ghi_chu}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
                <!-- Content end-->
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
