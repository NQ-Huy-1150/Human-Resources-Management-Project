<Page x:Class="layout.view.chamcong.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminPage">

    <Border Background="#F8F9FA">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,15,0,10">
                <Button Content="Quản lý nhân sự" Height="25" Click="OpenDashboard_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic" Foreground="#7F8C8D"/>
                <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                <TextBlock Text="Lịch sử chấm công toàn hệ thống" Margin="5,4,5,0" FontStyle="Italic" Foreground="#2C3E50" FontWeight="SemiBold"/>
            </StackPanel>

            <Rectangle Grid.Row="1" Fill="#D1D9E0" Margin="20,0"/>

            <DataGrid x:Name="dgAdmin" Grid.Row="2" Margin="20" AutoGenerateColumns="False" 
                      IsReadOnly="True" RowHeight="40" Background="White" BorderBrush="#D1D9E0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nhân Viên" Binding="{Binding full_name}" Width="1.5*"/>
                    <DataGridTextColumn Header="Thời điểm vào ca " Binding="{Binding check_in}" Width="*"/>
                    <DataGridTextColumn Header="Thời điểm tan ca" Binding="{Binding check_out}" Width="*"/>
                    <DataGridTextColumn Header="Loại ca" Binding="{Binding shift_type}" Width="*"/>
                    <DataGridTextColumn Header="Trạng Thái" Binding="{Binding status}" Width="*">
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</Page>