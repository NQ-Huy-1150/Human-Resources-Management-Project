<Page x:Class="layout.luong.NhanvienInfo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.luong"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="NhanvienInfo">

    <Grid Background="#F5F5F5">
        <StackPanel Orientation="Vertical" Margin="20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" Height="50">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="BẢNG LƯƠNG NHÂN VIÊN" Width="160" Background="White" BorderBrush="White" Height="37" Margin="0,0,5,0" Click="BtnBangLuong_Click"/>
                    <Button Content="THÔNG TIN NHÂN VIÊN" Height="38" Width="140" Background="White" BorderBrush="White" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnUpd" Content="Update" Width="100" Height="34" Background="#2196F3" Foreground="White" FontSize="12" FontWeight="Bold" Click="BtnUpd_Click" Margin="0,0,5,0"/>
                </StackPanel>
            </StackPanel>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20" Background="White" Height="81">
                <StackPanel>
                    <TextBlock Text="THÔNG TIN NHÂN VIÊN" FontSize="14" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,15"/>

                    <Grid Height="25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" Text="ID:" FontWeight="Bold" Margin="0,-3,10,23" Foreground="#555"/>
                        <TextBlock x:Name="TbId" Grid.Column="1" Grid.Row="0" Text="-" Margin="0,-3,20,23" Foreground="#333"/>

                        <TextBlock Grid.Column="2" Text="Tên NV:" FontWeight="Bold" Margin="10,-3,0,23" Foreground="#555"/>
                        <TextBlock x:Name="TbTenNV" Grid.Column="3" Text="-" Margin="32,-3,-12,23" Foreground="#333"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20" Background="White">
                <StackPanel>
                    <TextBlock Text="THÔNG TIN LƯƠNG" FontSize="14" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Lương Cơ Bản:" FontWeight="Bold" Margin="0,10,10,10" Foreground="#555"/>
                        <TextBlock x:Name="TbLuongCoBan" Grid.Column="1" Grid.Row="0" Text="-" Margin="0,10,20,10" Foreground="#333"/>

                        <TextBlock Grid.Column="2" Grid.Row="0" Text="Trợ Cấp:" FontWeight="Bold" Margin="0,10,10,10" Foreground="#555"/>
                        <TextBox x:Name="TbTroCap" Grid.Column="3" Grid.Row="0" Text="-" Margin="0,10,0,10" Foreground="#333"/>

                        <TextBlock Grid.Column="0" Grid.Row="1" Text="Thưởng:" FontWeight="Bold" Margin="0,10,10,10" Foreground="#555"/>
                        <TextBox x:Name="TbThuong" Grid.Column="1" Grid.Row="1" Text="-" Margin="0,10,20,10" Foreground="#333"/>

                        <TextBlock Grid.Column="2" Grid.Row="1" Text="Muộn (phút):" FontWeight="Bold" Margin="0,10,10,10" Foreground="#555"/>
                        <TextBlock x:Name="TbMuon" Grid.Column="3" Grid.Row="1" Text="-" Margin="0,10,0,10" Foreground="#333"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" Text="Khoản Trừ:" FontWeight="Bold" Margin="0,10,10,10" Foreground="#555"/>
                        <TextBox x:Name="TbKhoanTru" Grid.Column="1" Grid.Row="2" Text="-" Margin="0,10,20,10" Foreground="#333"/>

                        <TextBlock Grid.Column="2" Grid.Row="2" Text="Tháng/Năm:" FontWeight="Bold" Margin="0,10,10,10" Foreground="#555"/>
                        <TextBlock x:Name="TbThangNam" Grid.Column="3" Grid.Row="2" Text="-" Margin="0,10,0,10" Foreground="#333"/>

                        <TextBlock Grid.Column="0" Grid.Row="3" Text="Thực Lĩnh:" FontWeight="Bold" Margin="0,10,10,10" Foreground="#1B5E20" FontSize="14"/>
                        <TextBlock x:Name="TbThucLinh" Grid.Column="1" Grid.Row="3" Text="-" Margin="0,10,20,10" Foreground="#1B5E20" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Column="2" Grid.Row="3" Text="ID Lương:" FontWeight="Bold" Margin="0,10,10,10" Foreground="#555"/>
                        <TextBlock x:Name="TbIdLuong" Grid.Column="3" Grid.Row="3" Text="-" Margin="0,10,0,10" Foreground="#333"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Page>
