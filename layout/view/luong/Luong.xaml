<Page x:Class="layout.luong.Luong"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.luong"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Luong">

    <Grid Background="#F5F5F5">
        <StackPanel Orientation="Vertical" Margin="10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Quản lý nhân sự" Height="25" Click="OpenDashboard_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic" Foreground="#7F8C8D"/>
                <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                <TextBlock Text="Lương" Margin="5,4,5,0" FontStyle="Italic" />
            </StackPanel>
            <Grid>
                <Button Content="BẢNG LƯƠNG NHÂN VIÊN" Width="160" Click="Button_Click" Background="White" HorizontalAlignment="Left" BorderBrush="White"/>
                <Button Content="THÔNG TIN NHÂN VIÊN" Height="39" Width="140" Background="White" BorderBrush="White" HorizontalAlignment="Left" Margin="160,0,0,0" VerticalAlignment="Bottom" Click="Button_Click_1"/>
            </Grid>
            <TextBlock Height="23" TextWrapping="Wrap" Width="180" HorizontalAlignment="Center" Background="White" FontSize="16" Foreground="#FFCF2F2F"><Run FontWeight="Bold" Text="Bảng Lương Nhân Viên"/></TextBlock>
            <DataGrid x:Name="DgNhanVien" AutoGenerateColumns="False" RowHeight="40" CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding payroll_id}" Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Mã NV" Binding="{Binding user_id}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Tên NV" Binding="{Binding full_name}" Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Chức vụ" Binding="{Binding pos_name}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Lương cơ bản" Binding="{Binding base_salary}" Width="150" IsReadOnly="True" Foreground="#1B5E20" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Lương thực lĩnh" Binding="{Binding net_salary}" Width="*" IsReadOnly="True" Foreground="Red"  FontWeight="Bold"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>