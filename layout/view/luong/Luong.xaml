<Page x:Class="layout.luong.Luong"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.luong"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Luong">

    <Grid Background="#F5F5F5">
        <StackPanel Orientation="Vertical" Margin="10">
            <Grid>
                <Button Content="BẢNG LƯƠNG NHÂN VIÊN" Width="160" Click="Button_Click" Background="White" HorizontalAlignment="Left" BorderBrush="White"/>
                <Button Content="THÔNG TIN NHÂN VIÊN" Height="39" Width="140" Background="White" BorderBrush="White" HorizontalAlignment="Left" Margin="160,0,0,0" VerticalAlignment="Bottom" Click="Button_Click_1"/>
            </Grid>
            <TextBlock Height="23" TextWrapping="Wrap" Width="180" HorizontalAlignment="Center" Background="White" FontSize="16" Foreground="#FFCF2F2F"><Run FontWeight="Bold" Text="Bảng Lương Nhân Viên"/></TextBlock>
            <DataGrid x:Name="DgNhanVien" AutoGenerateColumns="False" RowHeight="40" CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Mã NV" Binding="{Binding NvId}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Tên NV" Binding="{Binding Name}" Width="250" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Thực Lĩnh" Binding="{Binding ThucLinh, StringFormat=N0}" Width="300" IsReadOnly="True" Foreground="#1B5E20" FontWeight="Bold"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>
