<UserControl x:Class="layout.view.Bars.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:layout.view.Bars"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="800">
    <Grid>
        <!-- TASK BAR START (Sidebar) -->
        <!-- Bọc thanh công cụ trong Border để đổ màu nền -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Orientation="Horizontal">
                <!-- Tiêu đề Menu -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="390,0,2,0" />
                    <Button Content="Tra cứu" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Padding="10" Click="lookUpBtn" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA37;" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="50,0,0,0" />
                    <Button Content="Tuyển dụng" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"  Padding="10" Click="jobListBtn"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA8C;" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="50,0,0,0" />
                    <Button Content="Đăng nhập" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Padding="10" Margin="0,0,10,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <!-- TASK BAR END -->

    </Grid>
</UserControl>
