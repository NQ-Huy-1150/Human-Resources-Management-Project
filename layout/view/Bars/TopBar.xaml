<UserControl x:Class="layout.view.Bars.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:layout.view.Bars"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="900">
    <Grid>
        <!-- TASK BAR START (Sidebar) -->
        <!-- Bọc thanh công cụ trong Border để đổ màu nền -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Orientation="Horizontal">
                <!-- Tiêu đề Menu -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="admin" FontFamily="Segoe MDL2 Assets" Text="&#xE7EF;" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="150,0,2,0"/>
                    <Button Content="Quản lý" x:Name="adminBtn" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Padding="10" Click="tkBtn_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="tk" FontFamily="Segoe MDL2 Assets" Text="&#xE7E7;" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="50,0,2,0"/>
                    <Button Content="Chấm công" x:Name="tkBtn" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Padding="10" Click="tkBtn_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="lookupSP" FontFamily="Segoe MDL2 Assets" Text="&#xE721;" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="50,0,2,0" />
                    <Button Content="Tra cứu" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Padding="10" Click="lookUpBtn" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE821;" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="50,0,0,0" />
                    <Button Content="Tuyển dụng" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"  Padding="10" Click="jobListBtn"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA8C;" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="50,0,0,0" />
                    <Button x:Name="logBtn" Content="Đăng nhập" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Padding="10" Margin="0,0,10,0" Click="login"/>
                    <TextBlock x:Name="show" Margin="10,0,0,0" Text="blablalb" FontSize="14" Foreground="White" VerticalAlignment="Center" Visibility="Collapsed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="logoutBtn" Visibility="Collapsed" Content="Đăng Xuất" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Padding="10" Margin="50,0,10,0" Click="logoutBtn_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <!-- TASK BAR END -->

    </Grid>
</UserControl>
