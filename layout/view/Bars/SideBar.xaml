<UserControl x:Class="layout.view.Bars.SideBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:layout.view.Bars"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!-- TASK BAR START (Sidebar) -->
        <!-- Bọc thanh công cụ trong Border để đổ màu nền -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <!-- Tiêu đề Menu -->
                <Button Content="Quản lý nhân sự" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="18" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,30" Click="Button_Click"/>
                <Button Content="Trang chủ" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" />
                <Button Content="Người dùng" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" />
                <Button Content="Phòng ban" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"/>
                <Button x:Name="btnRecruit" Content="Tuyển dụng" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Click="TuyenDungPage"/>
                <Button Content="Lương" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"/>
                <Button Content="Chấm công" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"/>
            </StackPanel>
        </Border>
        <!-- TASK BAR END -->

    </Grid>
</UserControl>
