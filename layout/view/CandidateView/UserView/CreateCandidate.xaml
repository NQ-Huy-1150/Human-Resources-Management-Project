<Page x:Class="layout.view.CandidateView.UserView.CreateCandidate"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.CandidateView.UserView"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateCandidate">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                
                <!-- Content start-->
                <Label Content="Ứng tuyển" HorizontalAlignment="Left" Height="37" Margin="10,51,0,0" VerticalAlignment="Top" Width="103" FontSize="18"/>
                <Rectangle Height="2" Margin="10,83,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <TextBlock x:Name="recruitId" Width="200" Visibility="Hidden" IsEnabled="False"/>
                <StackPanel Orientation="Vertical" Margin="10,95,10,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Vị trí ứng tuyển :" FontSize="14" Width="160" />
                        <TextBlock x:Name="position" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Họ và Tên :" FontSize="14" Width="160" />
                        <TextBox x:Name="name" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Email :" FontSize="14" Width="160" VerticalAlignment="Top"/>
                        <TextBox Width="200" x:Name="emailInput" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Số điện thoại :" FontSize="14" Width="160" />
                        <TextBox x:Name="phone" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Địa chỉ :" FontSize="14" Width="160" />
                        <TextBox x:Name="address" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Số năm kinh nghiệm :" FontSize="14" Width="160" />
                        <TextBox x:Name="exp" Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Trình độ học vấn :" FontSize="14" Width="160" />
                        <TextBox x:Name="edu" Width="200" />
                    </StackPanel>
                    <Rectangle Height="2" Margin="10,20,10,0" Fill="LightGray" VerticalAlignment="Bottom"/>
                    <Button Content="Ứng tuyển ngay ! " FontSize="14" VerticalAlignment="Center" Margin="0,5,0,15" Click="Button_Click"/>
                    <TextBlock Text="Hoặc" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Content="Quay lại danh sách " FontSize="14" VerticalAlignment="Center" Margin="0,5,0,15" Click="backToParentBtn"/>
                </StackPanel>
                <!-- Content end-->
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
