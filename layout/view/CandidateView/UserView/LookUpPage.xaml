<Page x:Class="layout.view.CandidateView.UserView.LookUpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.CandidateView.UserView"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LookUpPage">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Content start-->
                <Label Content="Tra cứu thông tin " HorizontalAlignment="Left" Height="37" Margin="10,51,0,51" VerticalAlignment="Top" Width="175" FontSize="18"/>
                <Rectangle Height="2" Margin="10,83,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Mã hồ sơ để tra cứu :" FontSize="14" Padding="5" Width="150"/>
                        <TextBox x:Name="id" FontSize="14" FontWeight="Bold" Padding="5" Width="250"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Trạng thái :" FontSize="14" Padding="5" Width="150"/>
                        <TextBlock x:Name="status" FontSize="14" FontWeight="Bold" Padding="5" Width="250"/>
                    </StackPanel>
                    <Button Content="Tra cứu" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,5" Click="Button_Click"/>
                    <TextBlock Text="Hoặc" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Content="Quay trở lại trang chủ " FontSize="14" VerticalAlignment="Center" Margin="0,5,0,15" Click="backToParentBtn"/>
                </StackPanel>
                <!-- Content end-->
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
