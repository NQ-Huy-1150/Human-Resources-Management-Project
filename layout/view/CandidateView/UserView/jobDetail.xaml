<Page x:Class="layout.view.CandidateView.UserView.jobDetail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.CandidateView.UserView"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="jobDetail">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Content start-->
                <Label Content="Chi tiết đơn tuyển dụng" HorizontalAlignment="Left" Height="37" Margin="10,20,0,0" VerticalAlignment="Top" Width="200" FontSize="18"/>
                <Rectangle Height="2" Margin="10,83,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <TextBlock x:Name="hiddenId" FontSize="14" Width="160" Visibility="Hidden" IsEnabled="False"/>
                <StackPanel Orientation="Vertical" Margin="10,95,10,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Mã phòng ban : " FontSize="14" Width="160" />
                        <TextBlock x:Name="departmentId" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Vị trí tuyển dụng :" FontSize="14" Width="160" />
                        <TextBlock x:Name="position" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Mức lương dự kiến :" FontSize="14" Width="160" />
                        <TextBlock x:Name="income" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Điều kiện tuyển dụng :" FontSize="14" Width="160" VerticalAlignment="Top"/>
                        <TextBox x:Name="condition" Width="200" AutomationProperties.Name="multi-line TextBox"
                        TextWrapping="Wrap" AcceptsReturn="True" MinLines="3" IsEnabled="False" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Mô tả công việc :" FontSize="14" Width="160" VerticalAlignment="Top"/>
                        <TextBox x:Name="desc" Width="200" AutomationProperties.Name="multi-line TextBox"
                        TextWrapping="Wrap" AcceptsReturn="True" MinLines="4" IsEnabled="False" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Hạn nộp hồ sơ dự kiến :" FontSize="14" Width="160" />
                        <TextBlock x:Name="dateShow" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Số lượng hồ sơ :" FontSize="14" Width="160" />
                        <TextBlock x:Name="quantity" Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Trạng thái :" FontSize="14" Width="160" />
                        <TextBlock x:Name="status" Width="200" />
                    </StackPanel>
                    <Rectangle Height="2" Margin="10,20,10,0" Fill="LightGray" VerticalAlignment="Bottom"/>
                    <Button Content="Ứng tuyển" FontSize="14" VerticalAlignment="Center" Margin="0,5,0,15" Click="createBtn"/>
                    <TextBlock Text="Hoặc" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Content="Quay lại danh sách " FontSize="14" VerticalAlignment="Center" Margin="0,5,0,15" Click="backToParentBtn"/>
                </StackPanel>
                <!-- Content end-->
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
