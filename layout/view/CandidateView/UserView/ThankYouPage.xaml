<Page x:Class="layout.view.CandidateView.UserView.ThankYouPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.CandidateView.UserView"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ThankYouPage">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Content start-->

                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
                    <TextBlock Text="Chúc mừng!" FontSize="20" Margin="0,0,0,10" Padding="10"/>
                    <TextBlock Text="Hồ sơ của bạn đã được gửi thành công." FontSize="14" Margin="0,0,0,10" Padding="5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Mã hồ sơ để tra cứu :" FontSize="14" Padding="5"/>
                        <TextBox x:Name="lookup" 
                                 FontSize="14" 
                                 FontWeight="Bold" 
                                 Padding="5" 
                                 IsReadOnly="True" 
                                 BorderThickness="0" 
                                 Background="Transparent" 
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="Quay trở về trang chủ" Padding="5"  Click="backToParentBtn"/>
                </StackPanel>
                <!-- Content end-->
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
