<UserControl x:Class="layout.view.CandidateView.UserView.show"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:layout.view.CandidateView.UserView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel Orientation="Vertical" Margin="10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Vị trí tuyển dụng : " FontSize="14" Width="150" />
                        <TextBlock Text="{Binding position}"  Width="150" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Phòng ban :" FontSize="14" Width="150" />
                        <TextBlock Text="{Binding ten_phongban}" Width="150" FontSize="14" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Mức lương dự kiến :" FontSize="14" Width="150" />
                        <TextBlock Text="{Binding estimateIncome}" Width="150" FontSize="14"/>
                    </StackPanel>


                    <Rectangle Height="2" Margin="10,20,10,0" Fill="LightGray" VerticalAlignment="Bottom"/>
                    <Button Content="Xem chi tiết" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,5" Click="Button_Click"/>
                </StackPanel>
                <!-- Content end-->
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
