<Page x:Class="layout.view.CandidateView.HRView.CandidatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.CandidateView.HRView"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CandidatePage">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Breadcrumb start -->
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" VerticalAlignment="Top">
                    <Button Content="Quản lý nhân sự" Height="25" Click="Button_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <Button Content="Tuyển dụng" Height="25" Click="backToParentBtn" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Danh sách ứng cử viên" Margin="5,4,5,0" FontStyle="Italic" />
                </StackPanel>
                <!-- Breadcrumb end -->

                <Rectangle Height="2" Margin="10,40,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <Label Content="Danh sách ứng cử viên" HorizontalAlignment="Left" Height="37" Margin="10,51,0,0" VerticalAlignment="Top" Width="193" FontSize="18"/>

                <StackPanel Orientation="Vertical" Margin="10,90,10,10"  VerticalAlignment="Top" HorizontalAlignment="Center">
                    <DataGrid x:Name="tableData" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã phiếu" Binding="{Binding id}" />
                            <DataGridTextColumn Header="Họ và tên" Binding="{Binding full_name}" />
                            <DataGridTextColumn Header="Email" Binding="{Binding email}" />
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding recruit_status}" />
                            <DataGridTemplateColumn Header="Chức năng" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Xem" Click="btnDetail" Padding="5,1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <Button Content="Cập nhật" Click="updateBnt" Padding="5,1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <Button Content="Xóa" Click="deleteBnt" Padding="5,1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
