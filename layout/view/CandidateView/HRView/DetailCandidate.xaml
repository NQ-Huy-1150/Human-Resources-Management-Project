<Page x:Class="layout.view.CandidateView.HRView.DetailCandidate"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.CandidateView.HRView"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DetailCandidate">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Breadcrumb start -->
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" VerticalAlignment="Top">
                    <Button Content="Quản lý nhân sự" Height="25" Click="Button_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <Button Content="Tuyển dụng" Height="25" Click="backToParentBtn" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Chi tiết đơn" Margin="5,4,5,0" FontStyle="Italic" />
                </StackPanel>
                <!-- Breadcrumb end -->
                <!-- Content start-->
                <Rectangle Height="2" Margin="10,40,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <Label Content="Chi tiết đơn ứng cử viên" HorizontalAlignment="Left" Height="37" Margin="10,51,0,0" VerticalAlignment="Top" Width="200" FontSize="18"/>
                <Rectangle Height="2" Margin="10,83,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <StackPanel Orientation="Vertical" Margin="10,95,10,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Mã phiếu : " FontSize="14" Width="160" />
                        <TextBlock x:Name="id" Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Mã đơn tuyển dụng : " FontSize="14" Width="160" />
                        <TextBlock x:Name="recruitId" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Vị trí tuyển dụng :" FontSize="14" Width="160" />
                        <TextBlock x:Name="position" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Họ và Tên :" FontSize="14" Width="160" />
                        <TextBlock x:Name="name" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Email :" FontSize="14" Width="160" VerticalAlignment="Top"/>
                        <TextBlock Width="200" x:Name="emailInput" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Số điện thoại :" FontSize="14" Width="160" />
                        <TextBlock x:Name="phone" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Địa chỉ :" FontSize="14" Width="160" />
                        <TextBlock x:Name="address" Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Số năm kinh nghiệm :" FontSize="14" Width="160" />
                        <TextBlock x:Name="exp" Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Trình độ học vấn :" FontSize="14" Width="160" />
                        <TextBlock x:Name="edu" Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Trạng thái :" FontSize="14" Width="160" />
                        <TextBlock x:Name="status" Width="200" />
                    </StackPanel>
                    <Rectangle Height="2" Margin="10,20,10,0" Fill="LightGray" VerticalAlignment="Bottom"/>
                    <Button Content="Quay lại bảng tuyển dụng " FontSize="14" VerticalAlignment="Center" Margin="0,5,0,15" Click="backToParentBtn"/>
                </StackPanel>
                <!-- Content end-->
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
