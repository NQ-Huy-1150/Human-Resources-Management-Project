<Window x:Class="layout.view.Main_Window.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:layout.view.Main_Window"
        xmlns:sidebar="clr-namespace:layout.view.Side_bar"
        mc:Ignorable="d"
        Title="Phần mềm Quản lý Nhân sự" Height="600" Width="1000">
    <Grid>
        <!-- Chia màn hình làm 2 cột: Cột trái cho Menu, Cột phải cho Nội dung -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Gọi UserControl SideBar -->
        <sidebar:SideBar Grid.Column="0" Loaded="SideBar_Loaded"/>
        
        <!-- Frame chứa các page nội dung -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
