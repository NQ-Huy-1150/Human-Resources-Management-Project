<Page x:Class="layout.view.Main_Window.HomeWelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="HomeWelcomePage">
    <Grid Background="#F5F5F5">
        <StackPanel Margin="24">
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="txtGreeting" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock x:Name="txtCurrentTime" Margin="0,8,0,0" FontSize="14" Foreground="#666666"/>
                </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="Gợi ý sử dụng nhanh" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="• Dùng mục Tra cứu để theo dõi hồ sơ ứng tuyển." Margin="0,10,0,0" Foreground="#555555"/>
                    <TextBlock Text="• Dùng mục Tuyển dụng để xem các vị trí đang mở." Margin="0,6,0,0" Foreground="#555555"/>
                    <TextBlock x:Name="txtAttendanceTip" Margin="0,6,0,0" Foreground="#555555"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
