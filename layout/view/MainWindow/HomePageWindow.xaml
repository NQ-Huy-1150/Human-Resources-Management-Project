<Window x:Class="layout.view.Main_Window.HomePageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:layout.view.Main_Window"
        xmlns:topbar="clr-namespace:layout.view.Bars"
        mc:Ignorable="d"
        Title="HomePageWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Gọi UserControl TopBar -->
        <topbar:TopBar Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="102"/>

        <!-- Frame chứa các page nội dung -->
        <Frame x:Name="HomeFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
