<Page x:Class="layout.view.Main_Window.AdminDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminDashboardPage">
    <Grid Background="#F4F6F9" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Quản lý nhân sự" FontStyle="Italic" Foreground="#7F8C8D"/>
            <TextBlock Text="/" Margin="6,0,6,0" Foreground="Gray"/>
            <TextBlock Text="Dashboard" FontStyle="Italic" Foreground="#2C3E50" FontWeight="SemiBold"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Thống kê nhanh"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#2C3E50"/>

        <UniformGrid Grid.Row="3" Columns="3" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <Border Margin="8"
                    Padding="20"
                    BorderBrush="#D0D7DE"
                    BorderThickness="2"
                    Background="White"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Số lượng nhân viên" FontSize="16" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBlock x:Name="employeeCountText" Text="0" FontSize="30" FontWeight="Bold" Margin="0,14,0,0" Foreground="#1F2937"/>
                </StackPanel>
            </Border>

            <Border Margin="8"
                    Padding="20"
                    BorderBrush="#D0D7DE"
                    BorderThickness="2"
                    Background="White"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Tổng lương tháng hiện tại" FontSize="16" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBlock x:Name="totalSalaryText" Text="0 VNĐ" FontSize="30" FontWeight="Bold" Margin="0,14,0,0" Foreground="#1F2937" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Margin="8"
                    Padding="20"
                    BorderBrush="#D0D7DE"
                    BorderThickness="2"
                    Background="White"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Số hồ sơ tuyển dụng" FontSize="16" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBlock x:Name="recruitmentProfileCountText" Text="0" FontSize="30" FontWeight="Bold" Margin="0,14,0,0" Foreground="#1F2937"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</Page>
