<Window x:Class="layout.view.Main_Window.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:layout.view.Main_Window"
        mc:Ignorable="d"
        Title="Đăng Nhập Hệ Thống" Height="450" Width="500"
        WindowStartupLocation="CenterScreen" Background="#F4F7F9" ResizeMode="NoResize">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="40">

            <TextBlock Text="ĐĂNG NHẬP" FontSize="28" FontWeight="Bold" 
                   HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,0,0,30"/>

            <TextBlock Text="Email:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="txtEmail" Height="40" VerticalContentAlignment="Center" 
                 Padding="10,0" Margin="0,0,0,20" FontSize="14"/>

            <TextBlock Text="Mật khẩu:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <PasswordBox x:Name="txtPassword" Height="40" VerticalContentAlignment="Center" 
                     Padding="10,0" Margin="0,0,0,25" FontSize="14"/>

            <Button Content="ĐĂNG NHẬP" Click="btnLogin_Click" Height="45" 
                Background="#3498DB" Foreground="White" FontWeight="Bold" 
                FontSize="16" Cursor="Hand" BorderThickness="0"/>

            <TextBlock HorizontalAlignment="Center" Margin="0,15,0,0">
            <Hyperlink Click="hlForgotPassword_Click" Foreground="#E74C3C" TextDecorations="None">
                Quên mật khẩu?
            </Hyperlink>
            </TextBlock>

        </StackPanel>
    </Grid>
</Window>
