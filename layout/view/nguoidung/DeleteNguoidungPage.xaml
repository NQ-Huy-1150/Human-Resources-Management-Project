<Page x:Class="layout.view.Nguoidung.DeleteNguoidungPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DeleteNguoidungPage">

    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" VerticalAlignment="Top">
                    <Button Content="Quản lý nhân sự" Height="25" Click="OpenDashboard_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <Button Content="Người dùng" Height="25" Click="BackToUsers_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Xóa người dùng" Margin="5,4,5,0" FontStyle="Italic"/>
                </StackPanel>

                <Rectangle Height="2" Margin="10,40,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <Label Content="Bạn chắc chắn muốn xóa người dùng này?" HorizontalAlignment="Left" Height="37" Margin="10,51,0,0" VerticalAlignment="Top" Width="368" FontSize="18" Foreground="Red" FontWeight="Bold"/>
                <Rectangle Height="2" Margin="10,83,10,0" Fill="LightGray" VerticalAlignment="Top"/>

                <StackPanel Orientation="Vertical" Margin="10,95,10,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" MinWidth="500">
                        <TextBlock Text="Mã người dùng :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtUserId" Width="220"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,12,0,0" MinWidth="500">
                        <TextBlock Text="Họ tên :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtBaseSalary" Width="220"/>
                    </StackPanel>

                    <Rectangle Height="2" Margin="10,20,10,0" Fill="LightGray" VerticalAlignment="Bottom"/>
                    <Button Content="Xóa người dùng" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,5" Click="Delete_Click" Background="OrangeRed" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="Hoặc" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Content="Quay lại danh sách người dùng" FontSize="14" VerticalAlignment="Center" Margin="0,5,0,15" Click="BackToUsers_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Page>