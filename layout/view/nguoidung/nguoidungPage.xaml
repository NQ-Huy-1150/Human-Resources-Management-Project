    <Page x:Class="layout.view.nguoidung.nguoidungPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.nguoidung"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="nguoidungPage">

    <!-- VÙNG NỘI DUNG CHÍNH -->
    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Breadcrumb start -->
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" VerticalAlignment="Top">
                    <TextBlock Text="Quản lý nhân sự" FontStyle="Italic" />
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Người dùng" Margin="5,4,5,0" FontStyle="Italic" />
                </StackPanel>
                <!-- Breadcrumb end -->

                <Rectangle Height="2" Margin="10,40,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <Label Content="Quản lý người dùng" HorizontalAlignment="Left" Height="37" Margin="10,51,0,0" VerticalAlignment="Top" Width="200" FontSize="18"/>

                <StackPanel Orientation="Vertical" Margin="10,90,10,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Top" HorizontalAlignment="Right">
                        <Button Content="Thêm" Width="120" Height="35" Margin="0,0,10,0" Click="Button_Click"/>
                        <Button Content="Lưu chỉnh sửa" Width="120" Height="35" Margin="0,0,10,0" Click="Button_Click_1"/>
                        <Button Content="Xóa" Width="120" Height="35" Click="Button_Click_2"/>
                    </StackPanel>

                    <DataGrid x:Name="NguoidungGrid" AutoGenerateColumns="True" CanUserAddRows="False"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
