<Page x:Class="layout.view.Nguoidung.UpdateNguoidungPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="UpdateNguoidungPage">

    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button Content="Quản lý nhân sự" Height="25" Click="OpenDashboard_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <Button Content="Người dùng" Height="25" Click="BackToUsers_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Cập nhật người dùng" Margin="5,4,5,0" FontStyle="Italic"/>
                </StackPanel>

                <TextBlock Text="Mã người dùng:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPos" Grid.Row="1" Grid.Column="1" Height="30" IsReadOnly="True" Background="#F1F3F5"/>

                <TextBlock Text="Họ tên:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtHoten" Grid.Row="2" Grid.Column="1" Height="30"/>

                <TextBlock Text="Email:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtEmail" Grid.Row="3" Grid.Column="1" Height="30" IsEnabled="False"/>

                <TextBlock Text="Mật khẩu:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtMatkhau" Grid.Row="4" Grid.Column="1" Height="30"/>

                <TextBlock Text="Địa chỉ:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtDiachi" Grid.Row="5" Grid.Column="1" Height="30"/>

                <TextBlock Text="Số điện thoại:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSodienthoai" Grid.Row="6" Grid.Column="1" Height="30"/>

                <TextBlock Text="Phòng ban:" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbPhongban" Grid.Row="7" Grid.Column="1" Height="30" DisplayMemberPath="department_name" SelectedValuePath="department_id"/>

                <TextBlock Text="Vai trò:" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbVaitro" Grid.Row="8" Grid.Column="1" Height="30" DisplayMemberPath="role_name" SelectedValuePath="role_id"/>

                <TextBlock Text="Chức vụ:" Grid.Row="9" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbChucvu" Grid.Row="9" Grid.Column="1" Height="30" DisplayMemberPath="pos_name" SelectedValuePath="pos_id"/>

                <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Lưu cập nhật" Width="130" Height="40" Margin="10" Click="Update_Click" Background="#F39C12" Foreground="White" BorderThickness="0"/>
                    <Button Content="Quay lại" Width="130" Height="40" Margin="10" Click="BackToUsers_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Page>