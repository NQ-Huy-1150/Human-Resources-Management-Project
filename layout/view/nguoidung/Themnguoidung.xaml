<Page x:Class="layout.view.Nguoidung.Themnguoidung"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.Nguoidung"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Themnguoidung">

    <Grid Margin="40">

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Họ tên -->
        <TextBlock Text="Họ tên:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtHoten" Grid.Row="0" Grid.Column="1" Height="30"/>

        <!-- Email -->
        <TextBlock Text="Email:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtEmail" Grid.Row="1" Grid.Column="1" Height="30"/>

        <!-- Mật khẩu -->
        <TextBlock Text="Mật khẩu:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <PasswordBox x:Name="txtMatkhau" Grid.Row="2" Grid.Column="1" Height="30"/>

        <!-- Nhập lại mật khẩu -->
        <TextBlock Text="Nhập lại mật khẩu:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <PasswordBox x:Name="txtMatkhau2" Grid.Row="3" Grid.Column="1" Height="30"/>

        <!-- Địa chỉ -->
        <TextBlock Text="Địa chỉ:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDiachi" Grid.Row="4" Grid.Column="1" Height="30"/>

        <!-- Số điện thoại -->
        <TextBlock Text="Số điện thoại:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtSodienthoai" Grid.Row="5" Grid.Column="1" Height="30"/>

        <!-- Phòng ban -->
        <TextBlock Text="Phòng ban:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbPhongban" Grid.Row="6" Grid.Column="1" Height="30">
            <ComboBoxItem Content="HR" Tag="HR"/>
            <ComboBoxItem Content="IT" Tag="IT"/>
            <ComboBoxItem Content="KT" Tag="KT"/>
        </ComboBox>

        <!-- Vai trò -->
        <TextBlock Text="Vai trò:" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbVaitro" Grid.Row="7" Grid.Column="1" Height="30">
            <ComboBoxItem Content="Quản trị viên" Tag="1"/>
            <ComboBoxItem Content="Nhân viên" Tag="2"/>
        </ComboBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="8"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Thêm"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="Button_Click"/>

            <Button Content="Hủy"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="Button_Click_1"/>

        </StackPanel>

    </Grid>
</Page>
