<Page x:Class="layout.view.Nguoidung.Themnguoidung"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:layout.view.Nguoidung"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Themnguoidung">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,5">
            <Button Content="Quản lý nhân sự" Height="25" Click="OpenDashboard_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic" Foreground="#7F8C8D"/>
            <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
            <Button Content="Người dùng" Height="25" Click="BackToUsers_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic" Foreground="#7F8C8D"/>
            <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
            <TextBlock Text="Thêm người dùng" Margin="5,4,5,0" FontStyle="Italic" />
        </StackPanel>

        <!-- Họ tên -->
        <TextBlock Text="Họ tên:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtHoten" Grid.Row="1" Grid.Column="1" Height="30"/>

        <!-- Email -->
        <TextBlock Text="Email:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtEmail" Grid.Row="2" Grid.Column="1" Height="30"/>

        <!-- Mật khẩu -->
        <TextBlock Text="Mật khẩu:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <PasswordBox x:Name="txtMatkhau" Grid.Row="3" Grid.Column="1" Height="30"/>

        <!-- Nhập lại mật khẩu -->
        <TextBlock Text="Nhập lại mật khẩu:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <PasswordBox x:Name="txtMatkhau2" Grid.Row="4" Grid.Column="1" Height="30"/>

        <!-- Địa chỉ -->
        <TextBlock Text="Địa chỉ:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDiachi" Grid.Row="5" Grid.Column="1" Height="30"/>

        <!-- Số điện thoại -->
        <TextBlock Text="Số điện thoại:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtSodienthoai" Grid.Row="6" Grid.Column="1" Height="30"/>

        <!-- Phòng ban -->
        <TextBlock Text="Phòng ban:" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbPhongban" Grid.Row="7" Grid.Column="1" Height="30" DisplayMemberPath="department_name" SelectedValuePath="department_id"/>

        <!-- Vai trò -->
        <TextBlock Text="Vai trò:" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbVaitro" Grid.Row="8" Grid.Column="1" Height="30" DisplayMemberPath="role_name" SelectedValuePath="role_id"/>

        <!-- Chức vụ -->
        <TextBlock Text="Chức vụ:" Grid.Row="9" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbChucvu" Grid.Row="9" Grid.Column="1" Height="30" DisplayMemberPath="pos_name" SelectedValuePath="pos_id"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="10"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Thêm"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="Button_Click"/>

            <Button Content="Hủy"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="Button_Click_1"/>

        </StackPanel>

    </Grid>
</Page>
