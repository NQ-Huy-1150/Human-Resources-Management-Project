<Page x:Class="layout.view.Nguoidung.UserDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="UserDetailPage">

    <Border Background="#F8F9FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" VerticalAlignment="Top">
                    <Button Content="Quản lý nhân sự" Height="25" Click="OpenDashboard_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <Button Content="Người dùng" Height="25" Click="BackToUsers_Click" BorderThickness="0" Background="Transparent" FontStyle="Italic"/>
                    <TextBlock Text="/" Margin="5,4,5,0" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="Chi tiết người dùng" Margin="5,4,5,0" FontStyle="Italic"/>
                </StackPanel>

                <Rectangle Height="2" Margin="10,40,10,0" Fill="LightGray" VerticalAlignment="Top"/>
                <Label Content="Chi tiết người dùng" HorizontalAlignment="Left" Height="37" Margin="10,51,0,0" VerticalAlignment="Top" Width="200" FontSize="18"/>
                <Rectangle Height="2" Margin="10,83,10,0" Fill="LightGray" VerticalAlignment="Top"/>

                <StackPanel Orientation="Vertical" Margin="10,95,10,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Mã người dùng :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtUserId" Width="220"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Họ tên :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtFullName" Width="220"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Email :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtEmail" Width="220"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Địa chỉ :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtAddress" Width="220" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Số điện thoại :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtPhone" Width="220"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Vai trò :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtRole" Width="220"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Phòng ban :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtDepartment" Width="220"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Chức vụ :" FontSize="14" Width="160"/>
                        <TextBlock x:Name="txtPosition" Width="220"/>
                    </StackPanel>

                    <Rectangle Height="2" Margin="10,20,10,0" Fill="LightGray" VerticalAlignment="Bottom"/>
                    <Button Content="Quay lại danh sách người dùng" FontSize="14" VerticalAlignment="Center" Margin="0,8,0,15" Click="BackToUsers_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Page>