<Window x:Class="WpfApp16.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp16"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <!-- Chia màn hình làm 2 cột: Cột trái cho Menu, Cột phải cho Nội dung -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TASK BAR START (Sidebar) -->
        <!-- Bọc thanh công cụ trong Border để đổ màu nền -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <!-- Tiêu đề Menu -->
                <Button Content="Quản lý nhân sự" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="18" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,30" Click="Button_Click"/>
                <Button Content="Trang chủ" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Click="Button_Click"/>
                <Button Content="Người dùng" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14" Click="Button_Click_1"/>
                <Button Content="Phòng ban" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"/>
                <Button Content="Tuyển dụng" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"/>
                <Button Content="Lương" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"/>
                <Button Content="Chấm công" Height="40" BorderThickness="0" Background="Transparent" Foreground="White" FontSize="14"/>
            </StackPanel>
        </Border>
        <!-- TASK BAR END -->

        <!-- VÙNG NỘI DUNG CHÍNH -->
        <!-- VÙNG NỘI DUNG CHÍNH -->
        <Border Grid.Column="1" Background="#F8F9FA">
            <Grid Margin="20,50,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Tiêu đề & Nút -->
                    <RowDefinition Height="*"/>
                    <!-- Bảng dữ liệu -->
                </Grid.RowDefinitions>

                <!-- Tiêu đề và Nút Thêm mới -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
                    <TextBlock Text="DANH SÁCH PHÒNG BAN" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <Button Content="+ Thêm phòng ban" Margin="20,0,0,0" Padding="10,5" Background="#27AE60" Foreground="White" BorderThickness="0" Click="BtnAdd_Click"/>
                </StackPanel>

                <!-- Bảng hiển thị danh sách -->
                <DataGrid x:Name="dgPhongBan" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                  Background="White" BorderBrush="LightGray" RowHeight="30" FontSize="14">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Phòng Ban" Binding="{Binding ma_phongban}" Width="150"/>

                        <!-- Khớp với cột ten_phongban trong SQL -->
                        <DataGridTextColumn Header="Tên Phòng Ban" Binding="{Binding ten_phongban}" Width="*"/>
                        <DataGridTemplateColumn Header="Thao tác" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Sửa" Margin="5,0" Click="BtnEdit_Click" Background="#F39C12" Foreground="White" BorderThickness="0" Padding="5,2"/>
                                        <Button Content="Xóa" Click="BtnDelete_Click" Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="5,2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
